APP_NAME=Davvy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=davvy
DB_USERNAME=davvy
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type, X-Requested-With, X-CSRF-TOKEN, Accept, Authorization
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@davvy.local"
MAIL_FROM_NAME="${APP_NAME}"

ENABLE_PUBLIC_REGISTRATION=false
ENABLE_OWNER_SHARE_MANAGEMENT=true
ENABLE_DAV_COMPATIBILITY_MODE=false
ENABLE_CONTACT_MANAGEMENT=false
ENABLE_CONTACT_CHANGE_MODERATION=false
CONTACT_CHANGE_REQUEST_RETENTION_DAYS=90
DAV_LOG_CLIENT_TRAFFIC=false
DAV_AUTH_THROTTLE_MAX_ATTEMPTS=20
DAV_AUTH_THROTTLE_DECAY_SECONDS=60
RUN_DB_MIGRATIONS=true
RUN_DB_SEED=false
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
TRUSTED_PROXIES=
