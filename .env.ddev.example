APP_NAME=Davvy
APP_ENV=local
APP_KEY=base64:MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
APP_DEBUG=true
APP_URL=https://davvy.ddev.site

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=db
DB_USERNAME=db
DB_PASSWORD=db

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS="Content-Type, X-Requested-With, X-CSRF-TOKEN, Accept, Authorization"
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@davvy.local"
MAIL_FROM_NAME="${APP_NAME}"
ONBOARDING_REQUIRE_PUBLIC_EMAIL_VERIFICATION=true
ONBOARDING_SEND_EMAILS=false
ONBOARDING_INVITE_EXPIRES_HOURS=72
ONBOARDING_VERIFICATION_EXPIRES_HOURS=24
ONBOARDING_EXPOSE_LINKS_WITHOUT_MAILER=true

ENABLE_PUBLIC_REGISTRATION=false
ENABLE_PUBLIC_REGISTRATION_REQUIRE_APPROVAL=false
ENABLE_OWNER_SHARE_MANAGEMENT=true
ENABLE_DAV_COMPATIBILITY_MODE=false
ENABLE_CONTACT_MANAGEMENT=false
ENABLE_CONTACT_CHANGE_MODERATION=false
CONTACT_CHANGE_REQUEST_RETENTION_DAYS=90
MILESTONE_BIRTHDAY_INCLUDE_LAST_NAME=true
MILESTONE_BIRTHDAY_PRIORITIZE_NICKNAME=true
MILESTONE_ANNIVERSARY_PAIR_INCLUDE_LAST_NAME=false
MILESTONE_ANNIVERSARY_PRIORITIZE_NICKNAME=true
ENABLE_TWO_FACTOR_ENFORCEMENT=false
TWO_FACTOR_GRACE_PERIOD_DAYS=14
ENABLE_AUTOMATED_BACKUPS=false
BACKUPS_LOCAL_ENABLED=true
BACKUPS_LOCAL_PATH=/var/www/html/storage/app/backups
BACKUPS_S3_ENABLED=false
BACKUPS_S3_DISK=s3
BACKUPS_S3_PREFIX=davvy-backups
BACKUPS_SCHEDULE_TIMES=02:30
BACKUPS_TIMEZONE=UTC
BACKUPS_WEEKLY_DAY=0
BACKUPS_MONTHLY_DAY=1
BACKUPS_YEARLY_MONTH=1
BACKUPS_YEARLY_DAY=1
BACKUPS_RETENTION_DAILY=7
BACKUPS_RETENTION_WEEKLY=4
BACKUPS_RETENTION_MONTHLY=12
BACKUPS_RETENTION_YEARLY=3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
DAV_LOG_CLIENT_TRAFFIC=false
DAV_AUTH_THROTTLE_MAX_ATTEMPTS=20
DAV_AUTH_THROTTLE_DECAY_SECONDS=60
RUN_DB_MIGRATIONS=true
RUN_DB_SEED=false
RUN_SCHEDULER=true
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
TRUSTED_PROXIES=
